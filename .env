# Vite environment variables (must be prefixed with VITE_ to expose to client).

# Base URL of the SavoryOps backend API (no trailing slash).
VITE_BACKEND_URL=https://backend.savoryops.com

# localStorage key for the admin authentication token.
VITE_AdminTOKEN_NAME=savoryopsadmin_token

# Public website URL used for the logo "home" link on the sign-in page.
VITE_HOME_URL=https://savoryops.com

# App URL (used by the logout flow if/when added).
VITE_URL=https://adminpanel.savoryops.com
